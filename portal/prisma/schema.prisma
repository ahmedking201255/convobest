// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id            String             @id @default(uuid())
  email         String             @unique
  password      String
  name          String?
  role          String             @default("USER") // USER, ADMIN
  otpCode       String?            // OTP Code for password resets
  otpExpires    DateTime?          // OTP expiration time
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  instances     WhatsAppInstance[]
  subscriptions Subscription[]
  campaigns     Campaign[]
  transactions  Transaction[]
  monthlyMessageUsages MonthlyMessageUsage[]
}

model RegistrationOtp {
  phone     String   @id
  codeHash  String
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}

model Subscription {
  id        String   @id @default(uuid())
  userId    String
  plan      String   // Starter, Pro, Enterprise
  status    String   // ACTIVE, EXPIRED, CANCELLED
  startDate DateTime @default(now())
  endDate   DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WhatsAppInstance {
  id            String             @id // Generated by Go Engine (Instance UUID)
  userId        String
  name          String
  jid           String?
  token         String
  status        String             @default("DISCONNECTED") // DISCONNECTED, CONNECTED
  createdAt     DateTime           @default(now())
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs          MessageLog[]
  inboxMessages InboxMessage[]
  chatContacts  ChatContact[]
  chatbotConfig ChatbotConfig?
  campaigns     Campaign[]
  keywordRules  KeywordRule[]
  woocommerceConfig WooCommerceConfig?
  googleSheetsConfig GoogleSheetsConfig?
}

model MessageLog {
  id          String           @id @default(uuid())
  instanceId  String
  number      String
  contactName String?
  text        String           @db.LongText
  type        String           // SENT, RECEIVED, FAILED
  status      String           @default("SENT") // SENT, DELIVERED, READ
  createdAt   DateTime         @default(now())
  instance    WhatsAppInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId, createdAt])
  @@index([instanceId, number, createdAt])
  @@index([instanceId, number, contactName])
}

model MonthlyMessageUsage {
  id        String   @id @default(uuid())
  userId    String
  period    String   // YYYY-MM in Africa/Cairo timezone
  sentCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
  @@index([period])
}

model InboxMessage {
  id          String           @id @default(uuid())
  instanceId  String
  number      String
  contactName String?
  text        String           @db.LongText
  type        String           // SENT, RECEIVED, FAILED
  status      String           @default("SENT") // SENT, DELIVERED, READ
  reactionFromMe     String?
  reactionFromClient String?
  createdAt   DateTime         @default(now())
  instance    WhatsAppInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId, createdAt])
  @@index([instanceId, number, createdAt])
  @@index([instanceId, number, contactName])
}

model ChatContact {
  id          String           @id @default(uuid())
  instanceId  String
  number      String
  contactName String?
  isGroup     Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  instance    WhatsAppInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@unique([instanceId, number])
  @@index([instanceId, contactName])
  @@index([instanceId, isGroup])
}

model ChatbotConfig {
  id                    String           @id @default(uuid())
  instanceId            String           @unique
  enabled               Boolean          @default(false)
  provider              String           @default("OPENAI") // OPENAI, GEMINI
  apiKey                String?
  systemPrompt          String           @default("أنت مساعد خدمة عملاء ذكي ومحترف. أجب باختصار وبأسلوب ودود.")
  useProductsSheet      Boolean          @default(false)
  productsSpreadsheetId String?
  productsSheetName     String?
  productsMapping       String?          // JSON: { nameCol: "A", priceCol: "B", descCol: "C", stockCol: "D" }
  instance              WhatsAppInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model Campaign {
  id              String              @id @default(uuid())
  userId          String
  instanceId      String
  name            String
  messageTemplate String
  attachmentUrl   String?             @db.LongText
  attachmentType  String?
  attachmentName  String?
  attachmentMime  String?
  status          String              @default("PENDING") // PENDING, RUNNING, COMPLETED, PAUSED
  delayMin        Int                 @default(5)
  delayMax        Int                 @default(15)
  createdAt       DateTime            @default(now())
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  instance        WhatsAppInstance    @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  recipients      CampaignRecipient[]
}

model CampaignRecipient {
  id            String    @id @default(uuid())
  campaignId    String
  number        String
  customMessage String?
  status        String    @default("PENDING") // PENDING, SENT, FAILED
  sentAt        DateTime?
  error         String?
  campaign      Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model Transaction {
  id            String    @id @default(uuid())
  userId        String
  plan          String    // Starter, Pro, Enterprise
  amount        Float     // in EGP
  senderAccount String    // Wallet number or InstaPay username
  status        String    @default("PENDING") // PENDING, SUCCESSFUL, FAILED
  createdAt     DateTime  @default(now())
  confirmedAt   DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KeywordRule {
  id         String           @id @default(uuid())
  instanceId String
  keyword    String
  matchType  String           @default("CONTAINS") // EXACT, CONTAINS
  replyText  String
  enabled    Boolean          @default(true)
  createdAt  DateTime         @default(now())
  instance   WhatsAppInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model WooCommerceConfig {
  id                      String           @id @default(uuid())
  instanceId              String           @unique
  apiKey                  String           @unique @default(uuid())
  enabled                 Boolean          @default(false)
  orderCreatedTemplate    String           @default("مرحباً {customer_name}، تم استلام طلبك رقم #{order_id} بنجاح بقيمة {order_total} {currency}. شكراً لتسوقك معنا!")
  orderProcessingTemplate String           @default("مرحباً {customer_name}، طلبك رقم #{order_id} قيد التحضير الآن وسنقوم بشحنه في أقرب وقت.")
  orderCompletedTemplate  String           @default("مرحباً {customer_name}، تم شحن طلبك رقم #{order_id} بنجاح وهو في طريقه إليك الآن. سعداء بخدمتك!")
  createdAt               DateTime         @default(now())
  instance                WhatsAppInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model GoogleSheetsConfig {
  id              String           @id @default(uuid())
  instanceId      String           @unique
  accessToken     String?
  refreshToken    String?
  expiryDate      DateTime?
  spreadsheetId   String?
  spreadsheetName String?
  sheetName       String?
  columnMapping   String?          // JSON string: { phone: "A", name: "B", vars: { "{المبلغ}": "C" } }
  enabled         Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  instance        WhatsAppInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}
